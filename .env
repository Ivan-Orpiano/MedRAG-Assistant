# --- Core ---
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# --- Datastores ---
DATABASE_URL=postgresql+psycopg2://medassist:medassist@postgres:5432/medassist
POSTGRES_PASSWORD=medassist
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=medassist_chunks

# --- Storage: local | s3 | supabase ---
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/storage
# S3 / Supabase Storage (S3-compatible endpoint)
S3_BUCKET=medassist-documents
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Retrieval / grounding ---
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATES=30
MIN_DENSE_SCORE=0.28
MIN_KEYWORD_RANK=0.05
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_RATIO=0.15

# --- OCR ---
OCR_ENABLED=true
OCR_LANGUAGES=eng

# --- Rate limiting (requests per window) ---
RATE_LIMIT_CHAT=30/60
RATE_LIMIT_UPLOAD=20/3600
RATE_LIMIT_DEFAULT=240/60

# --- Bootstrap admin (created by `python -m app.bootstrap`) ---
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me

# --- Frontend ---
API_BASE_URL=http://api:8000
NICEGUI_STORAGE_SECRET=change-me-too
